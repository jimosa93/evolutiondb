# Password for the admin login screen (set the same in hosting env vars)
ADMIN_PASSWORD=

DATABASE_HOST=
DATABASE_PORT=5432
DATABASE_NAME=
DATABASE_USER=
DATABASE_PASSWORD=

# Used by Prisma — single connection URL (copy values from the variables above).
# If the server does not use TLS, append ?sslmode=disable (or ?sslmode=require when TLS is required).
DATABASE_URL=
